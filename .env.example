# warden CLI configuration (env-file form).
#
# The CLI reads WARDEN_* keys from ./.env (this file, when copied) and from
# ~/.warden/env. Real environment variables and flags always win.
#
# Copy to .env for a repo-local setup, or put the same lines in ~/.warden/env
# to make the whole machine a dev box.

# dev = `warden login` targets the local Umbra dev server (http://localhost:5173)
# instead of production (https://nyxtra.dev). Remove when nyxtra.dev is live.
WARDEN_ENV=dev

# Or pin an exact deployment (beats WARDEN_ENV):
# WARDEN_ISSUER=https://umbra-control.<account>.workers.dev
